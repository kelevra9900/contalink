# --- CONFIGURACIÓN DE ENTORNO CONTALINK (PRODUCCIÓN) ---

# Entorno: production | development
ENVIRONMENT=production

# --- BASE DE DATOS (AWS RDS o PostgreSQL externo) ---
# Debe usar el driver asyncpg para FastAPI/SQLAlchemy async
# Ejemplo: postgresql+asyncpg://<usuario>:<password>@<host-rds>:<puerto>/<db_name>
DATABASE_URL=postgresql+asyncpg://xxx:xxx@xxxx.contalink.com/testinvoices

# --- REDIS (AWS ElastiCache o Contenedor Local) ---
# En docker-compose local o EC2 se usa: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# --- SEGURIDAD ---
# Dominios permitidos separados por comas (sin barra al final)
ALLOWED_ORIGINS=http://localhost,http://localhost:80,https://tu-dominio.com

# --- CONFIGURACIÓN DE CORREO (SMTP) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=tu_usuario_smtp
SMTP_PASSWORD=tu_password_smtp
EMAIL_FROM=no-reply@contalink-invoices.com
EMAIL_TO=team@example.com

# --- VARIABLES PARA PERFIL "dev" (Solo si usas la base de datos local de Docker) ---
DB_USER=developer
DB_PASSWORD=REPLACED_PASSWORD
DB_NAME=testinvoices
